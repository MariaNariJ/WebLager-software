<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16"
      alignment="TOP_LEFT"
      prefWidth="340"
      prefHeight="180"
      stylesheets="@app.css"
      styleClass="profile-popup"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.gui.SaveDocumentController">

    <padding>
        <Insets top="22"
                right="22"
                bottom="22"
                left="22"/>
    </padding>

    <Label text="Save Document"
           styleClass="popup-title"/>

    <Label text="Choose a name for the document before saving."
           wrapText="true"
           styleClass="popup-subtitle"/>

    <VBox spacing="6">

        <Label text="Document Name"
               styleClass="field-label-dark"/>

        <TextField fx:id="txtDocumentName"
                   promptText="Document 1"/>
    </VBox>

    <HBox spacing="10"
          alignment="CENTER_RIGHT">

        <Button text="Cancel"
                onAction="#onCancelClicked"
                styleClass="popup-cancel"/>

        <Button text="Save"
                onAction="#onSaveClicked"
                styleClass="popup-continue"/>
    </HBox>

</VBox>