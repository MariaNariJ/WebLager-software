<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="820.0" prefWidth="1440.0"
            styleClass="login-root"
            stylesheets="@app.css"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.gui.LoginController">

    <children>

        <Pane fx:id="loginPatternPane"
              styleClass="login-pattern-pane"
              AnchorPane.topAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"/>

        <StackPane alignment="CENTER"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0"
                   AnchorPane.topAnchor="0.0">

            <children>
                <VBox alignment="TOP_CENTER"
                      maxHeight="600.0"
                      maxWidth="420.0"
                      prefHeight="600.0"
                      prefWidth="420.0"
                      spacing="18.0"
                      styleClass="login-card">
                    <padding>
                        <Insets bottom="34.0" left="30.0" right="30.0" top="34.0"/>
                    </padding>

                    <children>
                        <VBox alignment="CENTER" spacing="12.0">
                            <children>
                                <StackPane maxHeight="94.0"
                                           maxWidth="94.0"
                                           minHeight="94.0"
                                           minWidth="94.0"
                                           styleClass="logo-box">
                                    <children>
                                        <ImageView fitWidth="100.0"
                                                   preserveRatio="true"
                                                   smooth="true"
                                                   styleClass="center-logo-image">
                                            <image>
                                                <Image url="@assets/Logo_DarkMode_Blue.png"/>                                            </image>
                                        </ImageView>
                                    </children>
                                </StackPane>

                                <Label styleClass="brand-title" text="WebLager"/>
                                <Label styleClass="login-title" text="Sign in to your account"/>
                                <Label fx:id="loginMessageLabel"
                                       styleClass="login-subtitle"
                                       text="Please enter your credentials to continue"
                                       wrapText="true"/>
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="field-label" text="Username"/>
                                <TextField fx:id="usernameField"
                                           promptText="Enter your username"
                                           styleClass="login-field"/>
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="field-label" text="Password"/>
                                <PasswordField fx:id="passwordField"
                                               promptText="Enter your password"
                                               styleClass="login-field"/>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_LEFT">
                            <!--<children>
                                <CheckBox fx:id="rememberMeCheckBox"
                                          styleClass="login-checkbox"
                                          text="Remember me"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Hyperlink styleClass="link-button"
                                           text="Forgot password?"/>
                            </children>-->
                        </HBox>

                        <Button fx:id="signInButton"
                                maxWidth="1.7976931348623157E308"
                                onAction="#btnSingIn"
                                styleClass="primary-button"
                                text="Sign In"/>

                        <VBox alignment="CENTER" spacing="0.0">
                            <children>
                                <Label styleClass="version-label" text="Version 1.0.0"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </StackPane>

    </children>
</AnchorPane>