<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="820.0" prefWidth="1440.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.gui.LoginController"
            style="-fx-background-color: linear-gradient(to bottom right, #07111E, #0B1728 45%, #091522 100%);">

    <children>
        <StackPane AnchorPane.topAnchor="0.0"
                   AnchorPane.rightAnchor="0.0"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0">

            <children>
                <VBox maxWidth="420.0"
                      prefWidth="420.0"
                      spacing="18.0"
                      style="-fx-background-color: rgba(13, 24, 39, 0.96); -fx-background-radius: 26; -fx-border-radius: 26; -fx-border-width: 1.5; -fx-border-color: #4F46E5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.45), 35, 0.25, 0, 12);">
                    <padding>
                        <Insets top="34.0" right="34.0" bottom="28.0" left="34.0" />
                    </padding>

                    <children>
                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button text="✕"
                                        mnemonicParsing="false"
                                        prefWidth="34.0"
                                        prefHeight="34.0"
                                        focusTraversable="false"
                                        style="-fx-background-color: transparent; -fx-text-fill: #A5B4C7; -fx-font-size: 18; -fx-cursor: hand;" />
                            </children>
                        </HBox>

                        <VBox alignment="CENTER" spacing="12.0">
                            <children>
                                <StackPane minWidth="70.0" minHeight="70.0" maxWidth="70.0" maxHeight="70.0"
                                           style="-fx-background-color: rgba(79, 70, 229, 0.18); -fx-background-radius: 18; -fx-border-color: rgba(79, 70, 229, 0.65); -fx-border-radius: 18; -fx-border-width: 1.2;">
                                    <children>
                                        <Label text="⬡"
                                               style="-fx-text-fill: #6D5EF7; -fx-font-size: 32; -fx-font-weight: 800;" />
                                    </children>
                                </StackPane>

                                <HBox alignment="CENTER" spacing="8.0">
                                    <children>
                                        <Label text="WebLager"
                                               style="-fx-text-fill: white; -fx-font-size: 34; -fx-font-weight: 800; -fx-font-family: 'Montserrat';" />
                                    </children>
                                </HBox>

                                <Label text="Sign in to your account"
                                       style="-fx-text-fill: #F8FAFC; -fx-font-size: 26; -fx-font-weight: 700; -fx-font-family: 'Montserrat';" />

                                <Label wrapText="true"
                                       text="Please enter your credentials to continue"
                                       style="-fx-text-fill: #94A3B8; -fx-font-size: 15; -fx-font-family: 'Montserrat';" />
                            </children>
                        </VBox>

                        <VBox spacing="10.0">
                            <children>
                                <Label text="Username"
                                       style="-fx-text-fill: #E2E8F0; -fx-font-size: 15; -fx-font-weight: 700; -fx-font-family: 'Montserrat';" />

                                <TextField fx:id="usernameField"
                                           promptText="Enter your username"
                                           prefHeight="48.0"
                                           style="-fx-background-color: #111C2C; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #22324A; -fx-border-width: 1.2; -fx-text-fill: white; -fx-prompt-text-fill: #64748B; -fx-font-size: 15; -fx-font-family: 'Montserrat'; -fx-padding: 0 14 0 14;" />
                            </children>
                        </VBox>

                        <VBox spacing="10.0">
                            <children>
                                <Label text="Password"
                                       style="-fx-text-fill: #E2E8F0; -fx-font-size: 15; -fx-font-weight: 700; -fx-font-family: 'Montserrat';" />

                                <PasswordField fx:id="passwordField"
                                               promptText="Enter your password"
                                               prefHeight="48.0"
                                               style="-fx-background-color: #111C2C; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #22324A; -fx-border-width: 1.2; -fx-text-fill: white; -fx-prompt-text-fill: #64748B; -fx-font-size: 15; -fx-font-family: 'Montserrat'; -fx-padding: 0 14 0 14;" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <CheckBox fx:id="rememberMeCheckBox"
                                          text="Remember me"
                                          style="-fx-text-fill: #E2E8F0; -fx-font-size: 14; -fx-font-family: 'Montserrat'; -fx-focus-color: #4F46E5; -fx-faint-focus-color: transparent;" />

                                <Region HBox.hgrow="ALWAYS" />

                                <Hyperlink text="Forgot password?"
                                           style="-fx-text-fill: #6D5EF7; -fx-font-size: 14; -fx-font-family: 'Montserrat';" />
                            </children>
                        </HBox>

                        <Button fx:id="signInButton"
                                text="🔒  Sign In"
                                mnemonicParsing="false"
                                prefHeight="52.0"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: linear-gradient(to right, #4F46E5, #5B4DF0); -fx-background-radius: 14; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: 800; -fx-font-family: 'Montserrat'; -fx-cursor: hand;" />

                        <HBox alignment="CENTER" spacing="12.0">
                            <children>
                                <Separator HBox.hgrow="ALWAYS" style="-fx-background-color: #22324A;" />
                                <Label text="or"
                                       style="-fx-text-fill: #94A3B8; -fx-font-size: 14; -fx-font-family: 'Montserrat';" />
                                <Separator HBox.hgrow="ALWAYS" style="-fx-background-color: #22324A;" />
                            </children>
                        </HBox>

                        <Button fx:id="windowsSignInButton"
                                text="Use Windows account"
                                prefHeight="50.0"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: transparent; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #334155; -fx-border-width: 1.2; -fx-text-fill: #E2E8F0; -fx-font-size: 17; -fx-font-weight: 700; -fx-font-family: 'Montserrat'; -fx-cursor: hand;" />

                        <VBox alignment="CENTER" spacing="6.0">
                            <children>
                                <Label text="Version 1.0.0"
                                       style="-fx-text-fill: #64748B; -fx-font-size: 13; -fx-font-family: 'Montserrat';" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</AnchorPane>
