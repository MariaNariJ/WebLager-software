<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="820.0" prefWidth="1440.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.gui.LoginController"
            stylesheets="@app.css"
            styleClass="login-root">

    <children>
        <StackPane AnchorPane.topAnchor="0.0"
                   AnchorPane.rightAnchor="0.0"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0">

            <children>
                <VBox maxWidth="420.0"
                      prefWidth="420.0"
                      spacing="18.0"
                      styleClass="login-card">
                    <padding>
                        <Insets top="34.0" right="34.0" bottom="28.0" left="34.0"/>
                    </padding>

                    <children>
                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="✕"
                                        mnemonicParsing="false"
                                        prefHeight="30.0"
                                        prefWidth="30.0"
                                        focusTraversable="false"
                                        styleClass="close-button"/>
                            </children>
                        </HBox>

                        <VBox alignment="CENTER" spacing="12.0">
                            <children>
                                <StackPane minWidth="64.0"
                                           minHeight="64.0"
                                           maxWidth="64.0"
                                           maxHeight="64.0"
                                           styleClass="logo-box">
                                    <children>
                                        <Label text="WL" styleClass="logo-icon"/>
                                    </children>
                                </StackPane>

                                <Label text="WebLager" styleClass="brand-title"/>
                                <Label text="Sign in to your account" styleClass="login-title"/>
                                <Label text="Please enter your credentials to continue"
                                       wrapText="true"
                                       styleClass="login-subtitle"/>
                            </children>
                        </VBox>

                        <VBox spacing="10.0">
                            <children>
                                <Label text="Username" styleClass="field-label"/>
                                <TextField fx:id="usernameField"
                                           promptText="Enter your username"
                                           prefHeight="46.0"
                                           styleClass="login-field"/>
                            </children>
                        </VBox>

                        <VBox spacing="10.0">
                            <children>
                                <Label text="Password" styleClass="field-label"/>
                                <PasswordField fx:id="passwordField"
                                               promptText="Enter your password"
                                               prefHeight="46.0"
                                               styleClass="login-field"/>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <CheckBox fx:id="rememberMeCheckBox"
                                          text="Remember me"
                                          styleClass="login-checkbox"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Hyperlink text="Forgot password?"
                                           styleClass="link-button"/>
                            </children>
                        </HBox>

                        <Button fx:id="signInButton"
                                text="Sign In"
                                prefHeight="50.0"
                                maxWidth="1.7976931348623157E308"
                                styleClass="primary-button"/>

                        <HBox alignment="CENTER" spacing="12.0">
                            <children>
                                <Separator HBox.hgrow="ALWAYS" styleClass="thin-separator"/>
                                <Label text="or" styleClass="divider-label"/>
                                <Separator HBox.hgrow="ALWAYS" styleClass="thin-separator"/>
                            </children>
                        </HBox>

                        <Button fx:id="windowsSignInButton"
                                text="Use Windows account"
                                prefHeight="48.0"
                                maxWidth="1.7976931348623157E308"
                                styleClass="secondary-button"/>

                        <VBox alignment="CENTER" spacing="6.0">
                            <children>
                                <Label text="Version 1.0.0" styleClass="version-label"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</AnchorPane>