<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<?import javafx.scene.control.TreeView?>
<AnchorPane fx:id="appRoot" prefHeight="820.0" prefWidth="1443.0" styleClass="app-root" stylesheets="@css/app.css,@css/userview.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.gui.UserviewController">

    <children>

        <!-- MAIN RESPONSIVE CONTENT -->
        <VBox fx:id="mainContent" fillWidth="true" spacing="8.0" AnchorPane.bottomAnchor="8.0" AnchorPane.leftAnchor="187.0" AnchorPane.rightAnchor="8.0" AnchorPane.topAnchor="7.0">

            <children>

                <!-- TOP MAIN AREA -->
                <HBox spacing="8.0" VBox.vgrow="ALWAYS" fillHeight="true">

                    <children>

                        <!-- SCANNED FILES PANEL -->
                        <VBox minWidth="230.0" prefWidth="266.0" spacing="14" styleClass="panel">
                            <padding>
                                <Insets bottom="14" left="14" right="14" top="16" />
                            </padding>

                            <children>
                                <Label styleClass="section-title" text="Scanned Files" />
                                <TextField fx:id="searchField" promptText="Search files..." styleClass="dark-field" />

                                <HBox alignment="CENTER_LEFT" spacing="8">

                                    <Label styleClass="tree-title" text="Files" />

                                    <Label fx:id="fileCountLabel" styleClass="count-pill" text="0" />

                                    <Region HBox.hgrow="ALWAYS" />

                                    <Button fx:id="listViewButton" onAction="#onListViewClicked" styleClass="view-toggle-button-active" text="☷">
                                        <tooltip>
                                            <Tooltip text="List view" />
                                        </tooltip>
                                    </Button>

                                    <Button fx:id="imageViewButton" onAction="#onImageViewClicked" styleClass="view-toggle-button" text="▦">
                                        <tooltip>
                                            <Tooltip text="Image view" />
                                        </tooltip>
                                    </Button>

                                </HBox>

                                <ScrollPane fitToHeight="true"
                                            fitToWidth="true"
                                            hbarPolicy="NEVER"
                                            styleClass="dark-scroll"
                                            vbarPolicy="AS_NEEDED"
                                            VBox.vgrow="ALWAYS">

                                    <content>

                                        <VBox alignment="TOP_LEFT"
                                              spacing="8">

                                            <Label text="Current Box"
                                                   styleClass="current-box-label"/>

                                            <TreeView fx:id="documentTreeView"
                                                      VBox.vgrow="ALWAYS"
                                                      styleClass="document-tree"/>

                                        </VBox>

                                    </content>

                                </ScrollPane>
                                <HBox spacing="10">

                                    <Button fx:id="btnFetchFiles" onAction="#onFetchFilesClicked" prefWidth="140" styleClass="primary-action" text="Scan Next" />

                                    <Button fx:id="btnSaveasDocument" onAction="#onSaveasDocumentClicked" prefWidth="170" styleClass="primary-action" text="Save Document" />

                                </HBox>

                                <VBox spacing="4" styleClass="scan-status">
                                    <Label fx:id="scanStatusLabel" styleClass="muted-text" text="No files loaded" />
                                </VBox>
                            </children>
                        </VBox>

                        <!-- CENTER DOCUMENT AREA -->
                        <VBox spacing="12" styleClass="panel" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="14" left="14" right="14" top="12" />
                            </padding>

                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="12">

                                    <Label fx:id="fileIndicatorLabel" styleClass="blue-text" text="No file selected" />

                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="rotationIndicator" styleClass="rotation-indicator" text="0°" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#onZoomOut" styleClass="small-button" text="−" />
                                    <Label fx:id="zoomLabel" styleClass="section-title" text="100%" />
                                    <Button onAction="#onZoomIn" styleClass="small-button" text="+" />
                                </HBox>

                                <ScrollPane fx:id="previewScrollPane" fitToHeight="false" fitToWidth="false" hbarPolicy="AS_NEEDED" pannable="true" styleClass="dark-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">

                                    <content>

                                        <StackPane alignment="CENTER" style="-fx-background-color: transparent;">

                                            <children>

                                                <ImageView fx:id="previewImage" preserveRatio="true" smooth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;" />

                                            </children>

                                        </StackPane>

                                    </content>

                                </ScrollPane>

                                <!-- TOOLBAR -->
                                <HBox alignment="CENTER" maxHeight="94.0" minHeight="94.0" prefHeight="105" spacing="2" styleClass="toolbar-card">

                                    <!-- Rotate Left -->
                                    <Button onAction="#onRotateLeft" prefHeight="80" prefWidth="110" styleClass="toolbar-button">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label styleClass="toolbar-icon" text="↺" />

                                                <Label styleClass="toolbar-label" text="Rotate Left" />

                                                <Label styleClass="toolbar-keybind" text="(Q or Crtl+Q)" />

                                            </VBox>
                                        </graphic>

                                    </Button>

                                    <!-- Rotate Right -->
                                    <Button onAction="#onRotateRight" prefHeight="80" prefWidth="110" styleClass="toolbar-button">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label styleClass="toolbar-icon" text="↻" />

                                                <Label styleClass="toolbar-label" text="Rotate Right" />

                                                <Label styleClass="toolbar-keybind" text="(E or Crtl+E)" />

                                            </VBox>
                                        </graphic>

                                    </Button>

                                    <!-- Reset Rotation -->
                                    <Button onAction="#onResetRotation" prefHeight="80" prefWidth="125" styleClass="toolbar-button">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label styleClass="toolbar-icon" text="⟲" />

                                                <Label styleClass="toolbar-label" text="Reset Rotation" />

                                                <Label styleClass="toolbar-keybind" text="(R)" />

                                            </VBox>
                                        </graphic>

                                    </Button>

                                    <!-- Reset Zoom -->
                                    <Button onAction="#onResetZoom" prefHeight="80" prefWidth="115" styleClass="toolbar-button">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label styleClass="toolbar-icon" text="▣" />

                                                <Label styleClass="toolbar-label" text="Reset Zoom" />

                                                <Label styleClass="toolbar-keybind" text="(0)" />

                                            </VBox>
                                        </graphic>

                                    </Button>

                                    <!-- Fit Width -->
                                    <Button onAction="#onFitToWidth" prefHeight="80" prefWidth="110" styleClass="toolbar-button">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label styleClass="toolbar-icon" text="↔" />

                                                <Label styleClass="toolbar-label" text="Fit Width" />

                                                <Label styleClass="toolbar-keybind" text="(F)" />

                                            </VBox>
                                        </graphic>

                                    </Button>

                                    <!-- Next File -->
                                    <Button onAction="#onNextFile" prefHeight="80" prefWidth="105" styleClass="toolbar-button">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label styleClass="toolbar-icon" text="→" />

                                                <Label styleClass="toolbar-label" text="Next File" />

                                                <Label styleClass="toolbar-keybind" text="(D)" />

                                            </VBox>
                                        </graphic>

                                    </Button>

                                    <!-- Previous File -->
                                    <Button onAction="#onPreviousFile" prefHeight="80" prefWidth="120" styleClass="toolbar-button">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label styleClass="toolbar-icon" text="←" />

                                                <Label styleClass="toolbar-label" text="Previous File" />

                                                <Label styleClass="toolbar-keybind" text="(A)" />

                                            </VBox>
                                        </graphic>

                                    </Button>

                                </HBox>

                            </children>
                        </VBox>

                        <!-- METADATA PANEL -->
                        <VBox fillWidth="true" maxWidth="400" minWidth="340" prefWidth="360" spacing="12" styleClass="panel">

                            <padding>
                                <Insets bottom="18" left="18" right="18" top="18" />
                            </padding>

                            <children>
                                <!-- BOX INFORMATION -->
                                <Label styleClass="tab-active" text="Box Information" />

                                <Separator styleClass="dark-separator" />

                                <Label styleClass="info-label" text="Client *" />

                                <TextField fx:id="txtClient" styleClass="dark-field" />


                                <Label styleClass="info-label" text="Box *" />

                                <TextField fx:id="txtBox" styleClass="dark-field" />

                                <Label styleClass="info-label" text="Active Scan Profile *" />

                                <TextField fx:id="txtProfile" editable="false" styleClass="dark-field" />

                                <VBox fx:id="dynamicMetadataContainer" fillWidth="true" maxWidth="Infinity" spacing="10" />

                                <!-- DOCUMENT INFORMATION -->
                                <Label styleClass="tab-active" text="Document Information" />

                                <Separator styleClass="dark-separator" />

                                <Label styleClass="info-label" text="Document Name" />
                                <TextField fx:id="txtDocumentName" styleClass="dark-field" />

                                <Label styleClass="info-label" text="Date *" />
                              <TextField fx:id="txtDate" styleClass="dark-field" />


                                <VBox spacing="8">

                                    <Label styleClass="info-label" text="Barcode" />

                                    <Label fx:id="barcodeLabel" maxWidth="Infinity" styleClass="barcode-display" text="No barcode found" />

                                </VBox>

                                <Region VBox.vgrow="ALWAYS"/>
                                <HBox spacing="12">

                                    <Region HBox.hgrow="ALWAYS"/>


                                    <Button fx:id="btnFinishBox"
                                            onAction="#onFinishBoxClicked"
                                            prefHeight="38.0"
                                            prefWidth="120.0"
                                            styleClass="primary-action"
                                            text="Finish Box" />

                                    <Button fx:id="btnSendToExport"
                                            onAction="#onSendToExportClicked"
                                            prefHeight="38.0"
                                            prefWidth="170.0"
                                            styleClass="primary-action"
                                            text="Send to Export" />

                                </HBox>

                                <VBox spacing="14" styleClass="status-card">
                                    <VBox.margin>
                                        <Insets top="6"/>
                                    </VBox.margin>

                                    <Label styleClass="info-label" text="Document Status" />

                                    <HBox alignment="CENTER_LEFT" spacing="10">

                                        <Circle radius="4" styleClass="status-dot" />

                                        <Label fx:id="documentStatusLabel"
                                               styleClass="status-text"
                                               text="Ready for scanning" />

                                    </HBox>

                                </VBox>

                            </children>
                        </VBox>

                    </children>
                </HBox>

            </children>
        </VBox>

        <!-- SIDEBAR -->
        <VBox fx:id="sidebar" layoutX="-180" layoutY="0" prefHeight="820" prefWidth="180" spacing="18" styleClass="sidebar" AnchorPane.bottomAnchor="0.0" AnchorPane.topAnchor="0.0">

            <padding>
                <Insets bottom="20" left="14" right="14" top="24" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fx:id="sidebarLogoImage" fitWidth="32" preserveRatio="true">
                        <image>
                            <Image url="@assets/Logo_DarkMode_Blue.png" />
                        </image>
                    </ImageView>
                    <Label styleClass="sidebar-logo-text" text="WebLager" />
                </HBox>

                <VBox spacing="10">
                    <Button fx:id="scanningButton" onAction="#onScanningClicked" styleClass="nav-button-active" text="Scanning" />
                    <Button fx:id="exportButton" onAction="#onExportClicked" styleClass="nav-button" text="Export" />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Button fx:id="sidebarLockButton" onAction="#onSidebarLockClicked" pickOnBounds="true" styleClass="sidebar-icon-button" text="⧉">
                            <tooltip>
                                <Tooltip text="Lock sidebar" />
                            </tooltip>
                        </Button>
                    </HBox>

                    <Label text="Press I for shortcuts"
                           styleClass="shortcut-hint"/>

                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="user-info-card">

                        <VBox spacing="0">
                            <Label fx:id="userNameLabel" styleClass="top-user" text="User" />

                            <Label fx:id="userRoleLabel" styleClass="top-role" text="User" />
                        </VBox>
                    </HBox>
                </VBox>


                <Button onAction="#onLogOutClicked" styleClass="nav-button" text="↩  Log out" />
            </children>
        </VBox>

        <!-- SIDEBAR HOVER TRIGGER -->
        <Pane fx:id="sidebarTrigger" layoutX="0" layoutY="0" prefWidth="20" style="-fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.topAnchor="0.0" />


        <!-- GLOBAL SHORTCUT OVERLAY -->
        <StackPane fx:id="shortcutOverlay"
                   alignment="CENTER"
                   managed="false"
                   visible="false"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0"
                   AnchorPane.topAnchor="0.0">

            <Pane style="-fx-background-color: rgba(0,0,0,0.25);" />

            <VBox alignment="TOP_CENTER"
                  maxHeight="420"
                  maxWidth="820"
                  prefWidth="820"
                  spacing="12"
                  styleClass="shortcut-popup">

                <Label styleClass="shortcut-title"
                       text="Keyboard Shortcuts" />

                <HBox alignment="TOP_CENTER"
                      spacing="70">

                    <!-- LEFT COLUMN -->
                    <VBox spacing="8">

                        <HBox styleClass="shortcut-row">
                            <Label styleClass="shortcut-key"
                                   text="I" />
                            <Label text="Toggle Shortcut Help" />
                        </HBox>

                        <HBox styleClass="shortcut-row">
                            <Label styleClass="shortcut-key"
                                   text="L" />
                            <Label text="Lock / Unlock Sidebar" />
                        </HBox>

                        <HBox styleClass="shortcut-row">
                            <Label styleClass="shortcut-key"
                                   text="F1" />
                            <Label text="Show Profile Description" />
                        </HBox>

                        <HBox styleClass="shortcut-row">
                            <Label styleClass="shortcut-key"
                                   text="Q / Ctrl+Q" />
                            <Label text="Rotate Left" />
                        </HBox>

                        <HBox styleClass="shortcut-row">
                            <Label styleClass="shortcut-key"
                                   text="E / Ctrl+E" />
                            <Label text="Rotate Right" />
                        </HBox>

                        <HBox styleClass="shortcut-row">
                            <Label styleClass="shortcut-key"
                                   text="R" />
                            <Label text="Reset Rotation" />
                        </HBox>

                        <HBox styleClass="shortcut-row">
                            <Label styleClass="shortcut-key"
                                   text="F5" />
                            <Label text="Open Scan Setup" />
                        </HBox>

                        <HBox styleClass="shortcut-row">
                            <Label styleClass="shortcut-key"
                                   text="S" />
                            <Label text="Save Document" />
                        </HBox>

                    </VBox>

                <!-- RIGHT COLUMN -->
                <VBox spacing="8">

                    <HBox styleClass="shortcut-row">
                        <Label styleClass="shortcut-key" text="0" />
                        <Label text="Reset Zoom" />
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label styleClass="shortcut-key" text="F" />
                        <Label text="Fit Width" />
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label styleClass="shortcut-key" text="D" />
                        <Label text="Next File" />
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label styleClass="shortcut-key" text="A" />
                        <Label text="Previous File" />
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label styleClass="shortcut-key" text="B" />
                        <Label text="Finish Box" />
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label styleClass="shortcut-key" text="Shift + Q" />
                        <Label text="Export Box" />
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label styleClass="shortcut-key" text="↑" />
                        <Label text="Previous Profile" />
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label styleClass="shortcut-key" text="↓" />
                        <Label text="Next Profile" />
                    </HBox>

                    </VBox>

                </HBox>

            </VBox>

        </StackPane>

    </children>
</AnchorPane>
