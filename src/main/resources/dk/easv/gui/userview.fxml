<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="appRoot" prefHeight="820.0" prefWidth="1443.0" styleClass="app-root" stylesheets="@app.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.gui.UserviewController">

    <children>

        <!-- MAIN RESPONSIVE CONTENT -->
        <VBox fx:id="mainContent" spacing="8.0" AnchorPane.bottomAnchor="8.0" AnchorPane.leftAnchor="187.0" AnchorPane.rightAnchor="8.0" AnchorPane.topAnchor="7.0">

            <children>

                <!-- TOP MAIN AREA -->
                <HBox spacing="8.0" VBox.vgrow="ALWAYS">

                    <children>

                        <!-- SCANNED FILES PANEL -->
                        <VBox minWidth="230.0" prefWidth="266.0" spacing="14" styleClass="panel">
                            <padding>
                                <Insets bottom="14" left="14" right="14" top="16" />
                            </padding>

                            <children>
                                <Label styleClass="section-title" text="Scanned Files" />
                                <TextField fx:id="searchField" promptText="Search files..." styleClass="dark-field" />

                                <HBox alignment="CENTER_LEFT" spacing="8">

                                    <Label styleClass="tree-title" text="Files" />

                                    <Label fx:id="fileCountLabel" styleClass="count-pill" text="0" />

                                    <Region HBox.hgrow="ALWAYS" />

                                    <Button fx:id="listViewButton" onAction="#onListViewClicked" styleClass="view-toggle-button-active" text="☷">
                                        <tooltip>
                                            <Tooltip text="List view" />
                                        </tooltip>
                                    </Button>

                                    <Button fx:id="imageViewButton" onAction="#onImageViewClicked" styleClass="view-toggle-button" text="▦">
                                        <tooltip>
                                            <Tooltip text="Image view" />
                                        </tooltip>
                                    </Button>

                                </HBox>

                                <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" styleClass="dark-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">

                                    <content>
                                        <VBox fx:id="fileListContainer" alignment="TOP_CENTER" spacing="8" />
                                    </content>
                                </ScrollPane>

                                <Label fx:id="qaWarningLabel"
                                       text="⚠ Send current document to QA before scanning next document"
                                       visible="false"
                                       managed="false"
                                       wrapText="true"
                                       styleClass="qa-warning-label" />

                                <HBox spacing="10">

                                    <Button fx:id="btnFetchFiles"
                                            onAction="#onFetchFilesClicked"
                                            styleClass="primary-action"
                                            text="Scan Next-F5"
                                            prefWidth="140"/>

                                    <Button fx:id="btnSaveasDocument"
                                            onAction="#onSaveasDocumentClicked"
                                            styleClass="primary-action"
                                            text="Save as Document"
                                            prefWidth="170"/>

                                </HBox>

                                <VBox spacing="4" styleClass="scan-status">
                                    <Label fx:id="scanStatusLabel" styleClass="muted-text" text="No files loaded" />
                                </VBox>
                            </children>
                        </VBox>

                        <!-- CENTER DOCUMENT AREA -->
                        <VBox spacing="12" styleClass="panel" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="14" left="14" right="14" top="12" />
                            </padding>

                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Button styleClass="small-button" text="‹" />
                                    <Label styleClass="blue-text" text="File 1 of 45" />
                                    <Label styleClass="muted-text" text="(Ref: 1)" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="rotationIndicator" styleClass="rotation-indicator" text="0°"/>
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#onZoomOut" styleClass="small-button" text="−" />
                                    <Label fx:id="zoomLabel" styleClass="section-title" text="100%" />
                                    <Button onAction="#onZoomIn" styleClass="small-button" text="+" />
                                </HBox>

                                <ScrollPane fx:id="previewScrollPane"
                                            fitToHeight="false"
                                            fitToWidth="false"
                                            pannable="true"
                                            hbarPolicy="AS_NEEDED"
                                            vbarPolicy="AS_NEEDED"
                                            styleClass="dark-scroll"
                                            VBox.vgrow="ALWAYS">

                                    <content>

                                        <StackPane alignment="CENTER"
                                                   style="-fx-background-color: transparent;">

                                            <children>

                                                <ImageView fx:id="previewImage"
                                                           preserveRatio="true"
                                                           smooth="true"
                                                           style="-fx-background-color: transparent; -fx-border-color: transparent;" />

                                            </children>

                                        </StackPane>

                                    </content>

                                </ScrollPane>

                                <!-- TOOLBAR -->
                                <HBox alignment="CENTER"
                                      spacing="2"
                                      prefHeight="105"
                                      minHeight="105"
                                      maxHeight="105"
                                      styleClass="toolbar-card">

                                    <!-- Rotate Left -->
                                    <Button onAction="#onRotateLeft"
                                            styleClass="toolbar-button"
                                            prefWidth="110"
                                            prefHeight="80">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label text="↺"
                                                       styleClass="toolbar-icon"/>

                                                <Label text="Rotate Left"
                                                       styleClass="toolbar-label"/>

                                                <Label text="(Q or Crtl+Q)"
                                                       styleClass="toolbar-keybind"/>

                                            </VBox>
                                        </graphic>

                                    </Button>

                                    <!-- Rotate Right -->
                                    <Button onAction="#onRotateRight"
                                            styleClass="toolbar-button"
                                            prefWidth="110"
                                            prefHeight="80">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label text="↻"
                                                       styleClass="toolbar-icon"/>

                                                <Label text="Rotate Right"
                                                       styleClass="toolbar-label"/>

                                                <Label text="(E or Crtl+E)"
                                                       styleClass="toolbar-keybind"/>

                                            </VBox>
                                        </graphic>

                                    </Button>

                                    <!-- Reset Rotation -->
                                    <Button onAction="#onResetRotation"
                                            styleClass="toolbar-button"
                                            prefWidth="125"
                                            prefHeight="80">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label text="⟲"
                                                       styleClass="toolbar-icon"/>

                                                <Label text="Reset Rotation"
                                                       styleClass="toolbar-label"/>

                                                <Label text="(R)"
                                                       styleClass="toolbar-keybind"/>

                                            </VBox>
                                        </graphic>

                                    </Button>

                                    <!-- Reset Zoom -->
                                    <Button onAction="#onResetZoom"
                                            styleClass="toolbar-button"
                                            prefWidth="115"
                                            prefHeight="80">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label text="▣"
                                                       styleClass="toolbar-icon"/>

                                                <Label text="Reset Zoom"
                                                       styleClass="toolbar-label"/>

                                                <Label text="(0)"
                                                       styleClass="toolbar-keybind"/>

                                            </VBox>
                                        </graphic>

                                    </Button>

                                    <!-- Fit Width -->
                                    <Button onAction="#onFitToWidth"
                                            styleClass="toolbar-button"
                                            prefWidth="110"
                                            prefHeight="80">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label text="↔"
                                                       styleClass="toolbar-icon"/>

                                                <Label text="Fit Width"
                                                       styleClass="toolbar-label"/>

                                                <Label text="(F)"
                                                       styleClass="toolbar-keybind"/>

                                            </VBox>
                                        </graphic>

                                    </Button>

                                    <!-- Next File -->
                                    <Button onAction="#onNextFile"
                                            styleClass="toolbar-button"
                                            prefWidth="105"
                                            prefHeight="80">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label text="→"
                                                       styleClass="toolbar-icon"/>

                                                <Label text="Next File"
                                                       styleClass="toolbar-label"/>

                                                <Label text="(D)"
                                                       styleClass="toolbar-keybind"/>

                                            </VBox>
                                        </graphic>

                                    </Button>

                                    <!-- Previous File -->
                                    <Button onAction="#onPreviousFile"
                                            styleClass="toolbar-button"
                                            prefWidth="120"
                                            prefHeight="80">

                                        <graphic>
                                            <VBox alignment="CENTER" spacing="2">

                                                <Label text="←"
                                                       styleClass="toolbar-icon"/>

                                                <Label text="Previous File"
                                                       styleClass="toolbar-label"/>

                                                <Label text="(A)"
                                                       styleClass="toolbar-keybind"/>

                                            </VBox>
                                        </graphic>

                                    </Button>

                                </HBox>

                            </children>
                        </VBox>

                        <!-- METADATA PANEL -->
                        <VBox spacing="10"
                              minWidth="350"
                              prefWidth="350"
                              styleClass="panel">

                            <padding>
                                <Insets bottom="18" left="18" right="18" top="18" />
                            </padding>

                            <children>
                                <!-- BOX INFORMATION -->
                                <Label styleClass="tab-active"
                                       text="Box Information" />

                                <Separator styleClass="dark-separator" />

                                <Label styleClass="field-label-dark"
                                       text="Client *" />

                                <TextField fx:id="txtClient"
                                           styleClass="dark-field" />

                                <Label styleClass="field-label-dark"
                                       text="Box *" />

                                <TextField fx:id="txtBox"
                                           styleClass="dark-field" />

                                <Label styleClass="field-label-dark"
                                       text="Active Scan Profile" />

                                <TextField fx:id="txtProfile"
                                           editable="false"
                                           styleClass="dark-field" />

                                <VBox fx:id="dynamicMetadataContainer"
                                      spacing="10"
                                      fillWidth="true"
                                      maxWidth="Infinity"/>

                                <!-- DOCUMENT INFORMATION -->
                                <Label styleClass="tab-active"
                                       text="Document Information" />

                                <Separator styleClass="dark-separator" />

                                <Label styleClass="field-label-dark" text="Document Name" />
                                <TextField fx:id="txtDocumentName" styleClass="dark-field" />

                              <Label styleClass="field-label-dark" text="Date *" />
                              <TextField fx:id="txtDate" styleClass="dark-field" />

                                <VBox spacing="8">

                                    <Label text="Barcode"
                                           styleClass="field-label-dark"/>

                                    <Label fx:id="barcodeLabel"
                                           styleClass="barcode-display"
                                           maxWidth="Infinity"
                                           text="No barcode found"/>

                                </VBox>


                                <Region VBox.vgrow="ALWAYS" />

                                <VBox spacing="14"
                                      styleClass="status-card">

                                    <Label text="Document Status"
                                           styleClass="field-label-dark"/>

                                    <HBox spacing="10" alignment="CENTER_LEFT">

                                        <Label text="●"
                                               styleClass="status-dot"/>

                                        <Label fx:id="documentStatusLabel"
                                               text="Ready for scanning"
                                               styleClass="status-text"/>

                                    </HBox>

                                </VBox>
                                <Button onAction="#onReadyForQAClicked"
                                        prefHeight="38.0"
                                        prefWidth="149.0"
                                        styleClass="primary-action"
                                        text="Save and send to QA" />
                            </children>
                        </VBox>

                  </children>
              </HBox>

                <!-- BOTTOM SHELF -->
                <VBox spacing="0" styleClass="panel" HBox.hgrow="ALWAYS">

                    <!-- CLICKABLE HEADER -->
                    <StackPane fx:id="shelfHeader" onMouseClicked="#toggleBottomShelf" styleClass="shelf-header">

                        <!-- Left aligned title -->
                        <HBox alignment="CENTER_LEFT">
                            <Label prefHeight="18.0" prefWidth="135.0" styleClass="shelf-title" text="Document Overview" />
                        </HBox>

                        <!-- Centered arrow -->
                        <Label fx:id="shelfArrow" alignment="CENTER" prefHeight="18.0" prefWidth="28.0" styleClass="shelf-arrow" text="▲" />
                    </StackPane>

                    <!-- COLLAPSIBLE CONTENT -->
                    <VBox fx:id="shelfContent"
                          spacing="10"
                          styleClass="shelf-content"/>

                </VBox>

            </children>
        </VBox>

        <!-- SIDEBAR -->
        <VBox fx:id="sidebar" layoutX="-180" layoutY="0" prefHeight="820" prefWidth="180" spacing="18" styleClass="sidebar" AnchorPane.bottomAnchor="0.0" AnchorPane.topAnchor="0.0">

            <padding>
                <Insets bottom="20" left="14" right="14" top="24" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fx:id="sidebarLogoImage" fitWidth="32" preserveRatio="true">
                        <image>
                            <Image url="@assets/Logo_DarkMode_Blue.png" />
                        </image>
                    </ImageView>
                    <Label styleClass="sidebar-logo-text" text="WebLager" />
                </HBox>

                <VBox spacing="10">
                    <Button fx:id="scanningButton"
                            onAction="#onScanningClicked"
                            styleClass="nav-button-active"
                            text="Scanning" />

                    <Button fx:id="qaButton"
                            onAction="#onQaClicked"
                            styleClass="nav-button"
                            text="QA" />

                    <Button fx:id="exportButton"
                            onAction="#onExportClicked"
                            styleClass="nav-button"
                            text="Export" />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Button fx:id="themeToggleButton"
                                onAction="#onThemeToggleClicked"
                                styleClass="sidebar-icon-button"
                                text="☀"
                                pickOnBounds="true">
                            <tooltip>
                                <Tooltip text="Switch theme" />
                            </tooltip>
                        </Button>

                        <Button fx:id="sidebarLockButton"
                                onAction="#onSidebarLockClicked"
                                styleClass="sidebar-icon-button"
                                text="⧉"
                                pickOnBounds="true">
                            <tooltip>
                                <Tooltip text="Lock sidebar" />
                            </tooltip>
                        </Button>
                    </HBox>

                    <HBox alignment="CENTER_LEFT"
                          spacing="10"
                          styleClass="user-info-card">

                        <VBox spacing="0">
                            <Label fx:id="userNameLabel"
                                   styleClass="top-user"
                                   text="User" />

                            <Label fx:id="userRoleLabel"
                                   styleClass="top-role"
                                   text="User" />
                        </VBox>
                    </HBox>
                </VBox>

                <Button onAction="#onLogOutClicked" styleClass="nav-button" text="↩  Log out" />
            </children>
        </VBox>

        <!-- SIDEBAR HOVER TRIGGER -->
        <Pane fx:id="sidebarTrigger" layoutX="0" layoutY="0" prefWidth="20" style="-fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.topAnchor="0.0" />

        <!-- GLOBAL SHORTCUT OVERLAY -->
        <StackPane fx:id="shortcutOverlay"
                   visible="false"
                   managed="false"
                   alignment="CENTER"
                   AnchorPane.topAnchor="0.0"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0">

            <!-- Background dim -->
            <Pane style="-fx-background-color: rgba(0,0,0,0.25);" />

            <!-- Popup -->
            <VBox spacing="12"
                  alignment="TOP_CENTER"
                  maxWidth="700"
                  prefWidth="700"
                  maxHeight="420"
                  styleClass="shortcut-popup">

                <Label text="Keyboard Shortcuts"
                       styleClass="shortcut-title"/>

            <HBox spacing="40" alignment="TOP_CENTER">

                <!-- LEFT COLUMN -->
                <VBox spacing="8">

                    <HBox styleClass="shortcut-row">
                        <Label text="I"
                               styleClass="shortcut-key"/>
                        <Label text="Toggle Shortcut Help"/>
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label text="Q / Ctrl+Q"
                               styleClass="shortcut-key"/>
                        <Label text="Rotate Left"/>
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label text="E / Ctrl+E"
                               styleClass="shortcut-key"/>
                        <Label text="Rotate Right"/>
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label text="R"
                               styleClass="shortcut-key"/>
                        <Label text="Reset Rotation"/>
                    </HBox>

                </VBox>

                <!-- RIGHT COLUMN -->
                <VBox spacing="8">

                    <HBox styleClass="shortcut-row">
                        <Label text="0"
                               styleClass="shortcut-key"/>
                        <Label text="Reset Zoom"/>
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label text="F"
                               styleClass="shortcut-key"/>
                        <Label text="Fit Width"/>
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label text="D"
                               styleClass="shortcut-key"/>
                        <Label text="Next File"/>
                    </HBox>

                    <HBox styleClass="shortcut-row">
                        <Label text="A"
                               styleClass="shortcut-key"/>
                        <Label text="Previous File"/>
                    </HBox>

                </VBox>

            </HBox>

            </VBox>

        </StackPane>


    </children>
</AnchorPane>
