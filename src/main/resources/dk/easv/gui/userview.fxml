<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="820.0" prefWidth="1443.0" styleClass="app-root" stylesheets="@app.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.gui.UserviewController">

    <children>

        <!-- MAIN RESPONSIVE CONTENT -->
        <VBox fx:id="mainContent" spacing="8.0" AnchorPane.bottomAnchor="8.0" AnchorPane.leftAnchor="187.0" AnchorPane.rightAnchor="8.0" AnchorPane.topAnchor="7.0">

            <children>

                <!-- TOP MAIN AREA -->
                <HBox spacing="8.0" VBox.vgrow="ALWAYS">

                    <children>

                        <!-- SCANNED FILES PANEL -->
                        <VBox minWidth="230.0" prefWidth="266.0" spacing="14" styleClass="panel">
                            <padding>
                                <Insets bottom="14" left="14" right="14" top="16" />
                            </padding>

                            <children>
                                <Label styleClass="section-title" text="Scanned Files" />
                                <TextField fx:id="searchField" promptText="Search files..." styleClass="dark-field" />

                                <HBox alignment="CENTER_LEFT" spacing="8">

                                    <Label styleClass="tree-title" text="Files" />

                                    <Label fx:id="fileCountLabel" styleClass="count-pill" text="0" />

                                    <Region HBox.hgrow="ALWAYS" />

                                    <Button fx:id="listViewButton" onAction="#onListViewClicked" styleClass="view-toggle-button-active" text="☷">
                                        <tooltip>
                                            <Tooltip text="List view" />
                                        </tooltip>
                                    </Button>

                                    <Button fx:id="imageViewButton" onAction="#onImageViewClicked" styleClass="view-toggle-button" text="▦">
                                        <tooltip>
                                            <Tooltip text="Image view" />
                                        </tooltip>
                                    </Button>

                                </HBox>

                                <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" styleClass="dark-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">

                                    <content>
                                        <VBox fx:id="fileListContainer" alignment="TOP_CENTER" spacing="8" />
                                    </content>
                                </ScrollPane>

                                <Button fx:id="btnFetchFiles" onAction="#onFetchFilesClicked" styleClass="primary-action" text="+  Scan Next (F5)" />

                                <VBox spacing="4" styleClass="scan-status">
                                    <Label fx:id="scanStatusLabel" styleClass="muted-text" text="No files loaded" />
                                </VBox>
                            </children>
                        </VBox>

                        <!-- CENTER DOCUMENT AREA -->
                        <VBox spacing="12" styleClass="panel" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="14" left="14" right="14" top="12" />
                            </padding>

                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Button styleClass="small-button" text="‹" />
                                    <Label styleClass="blue-text" text="File 1 of 45" />
                                    <Label styleClass="muted-text" text="(Ref: 1)" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#onZoomOut" styleClass="small-button" text="−" />
                                    <Label fx:id="zoomLabel" styleClass="section-title" text="100%" />
                                    <Button onAction="#onZoomIn" styleClass="small-button" text="+" />
                                </HBox>

                                <ScrollPane fx:id="previewScrollPane" fitToHeight="true" fitToWidth="true" pannable="true" styleClass="dark-scroll" VBox.vgrow="ALWAYS">
                                    <content>
                                        <StackPane alignment="CENTER" minHeight="0" style="-fx-background-color: transparent;">
                                            <ImageView fx:id="previewImage" preserveRatio="true" smooth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;" />
                                        </StackPane>
                                    </content>
                                </ScrollPane>

                <!-- TOOLBAR -->
                <HBox alignment="CENTER" spacing="20" styleClass="toolbar-card" prefHeight="80" minHeight="80" maxHeight="80">
                    <Button onAction="#onRotateLeft" styleClass="toolbar-button" text="↺&#10;Rotate Left&#10;(Q)" />
                    <Button onAction="#onRotateRight" styleClass="toolbar-button" text="↻&#10;Rotate Right&#10;(E)" />
                    <Button onAction="#onFitToWidth" styleClass="toolbar-button" text="↔&#10;Fit Width" />
                    <Button onAction="#onResetZoom" styleClass="toolbar-button" text="▣&#10;Actual Size" />
                    <Button onAction="#onNextFile" styleClass="toolbar-button" text="→&#10;Next File&#10;(D)" />
                    <Button onAction="#onPreviousFile" styleClass="toolbar-button" text="←&#10;Previous File&#10;(A)" />
                </HBox>

                            </children>
                        </VBox>

                        <!-- METADATA PANEL -->
                        <VBox minWidth="320.0" prefWidth="350.0" spacing="14" styleClass="panel">
                            <padding>
                                <Insets bottom="18" left="18" right="18" top="18" />
                            </padding>

                            <children>
                                <HBox spacing="30">
                                    <Label styleClass="tab-active" text="Metadata" />
                                  <Label styleClass="tab-inactive" text="Info" />
                              </HBox>

                              <Separator styleClass="dark-separator" />

                              <Label styleClass="field-label-dark" text="Client *" />
                      <TextField fx:id="txtClient" styleClass="dark-field" />

                              <Label styleClass="field-label-dark" text="Box *" />
                      <TextField fx:id="txtBox" styleClass="dark-field" />

                              <Label styleClass="field-label-dark" text="Document Name *" />
                              <TextField fx:id="txtDocumentName" styleClass="dark-field" />

                              <Label styleClass="field-label-dark" text="Document Type" />
                              <TextField fx:id="txtDocumentType" styleClass="dark-field" />

                              <Label styleClass="field-label-dark" text="Date *" />
                              <TextField fx:id="txtDate" styleClass="dark-field" />

                              <Label styleClass="field-label-dark" text="Barcode" />
                              <Label fx:id="barcodeLabel" styleClass="muted-text" text="No barcode found" />

                              <Label opacity="0.0" styleClass="field-label-dark" text="Status" />
                              <ComboBox maxWidth="1.7976931348623157E308" opacity="0.0" promptText="In Progress" styleClass="combo-dark" />
                      <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS" />

              <Button minHeight="-Infinity" minWidth="-Infinity" onAction="#onSaveMetadataClicked" prefHeight="38.0" prefWidth="149.0" styleClass="primary-action" text="💾  Save Metadata (F2)" />
          </children>
      </VBox>

                  </children>
              </HBox>

                <!-- BOTTOM SHELF -->
                <VBox spacing="0" styleClass="panel" HBox.hgrow="ALWAYS">

                    <!-- CLICKABLE HEADER -->
                    <StackPane fx:id="shelfHeader" onMouseClicked="#toggleBottomShelf" styleClass="shelf-header">

                        <!-- Left aligned title -->
                        <HBox alignment="CENTER_LEFT">
                            <Label prefHeight="18.0" prefWidth="135.0" styleClass="shelf-title" text="Document Overview" />
                        </HBox>

                        <!-- Centered arrow -->
                        <Label fx:id="shelfArrow" alignment="CENTER" prefHeight="18.0" prefWidth="28.0" styleClass="shelf-arrow" text="▲" />
                    </StackPane>

                    <!-- COLLAPSIBLE CONTENT -->
                    <VBox fx:id="shelfContent" spacing="10" styleClass="shelf-content">

                        <HBox spacing="12">

                            <VBox prefWidth="190" spacing="6" styleClass="mini-card">
                                <Label styleClass="section-title" text="Document 1" />
                                <Label styleClass="muted-text" text="Files: 12" />
                                <Label styleClass="muted-text" text="Status: In Progress" />
                            </VBox>

                            <VBox prefWidth="190" spacing="6" styleClass="mini-card">
                                <Label styleClass="section-title" text="Document 2" />
                                <Label styleClass="muted-text" text="Files: 18" />
                                <Label styleClass="muted-text" text="Status: Waiting for QA" />
                            </VBox>

                            <VBox prefWidth="190" spacing="6" styleClass="mini-card">
                                <Label styleClass="section-title" text="Document 3" />
                                <Label styleClass="muted-text" text="Files: 15" />
                                <Label styleClass="muted-text" text="Status: Not Started" />
                            </VBox>

                        </HBox>
                    </VBox>

                </VBox>

            </children>
        </VBox>

        <!-- SIDEBAR -->
        <VBox fx:id="sidebar" layoutX="-180" layoutY="0" prefHeight="820" prefWidth="180" spacing="18" styleClass="sidebar" AnchorPane.bottomAnchor="0.0" AnchorPane.topAnchor="0.0">

            <padding>
                <Insets bottom="20" left="14" right="14" top="24" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitWidth="32" preserveRatio="true">
                        <image>
                            <Image url="@assets/Logo_DarkMode_Blue.png" />
                        </image>
                    </ImageView>
                    <Label styleClass="sidebar-logo-text" text="WebLager" />
                </HBox>

                <VBox spacing="10">
                    <Button styleClass="nav-button-active" text="▣  Scanning" />
                    <Button styleClass="nav-button" text="□  Documents" />
                    <Button styleClass="nav-button" text="☑  QA" />
                    <Button styleClass="nav-button" text="⇧  Export" />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label styleClass="sidebar-icon" text="☀">
                            <tooltip>
                                <Tooltip text="Switch theme" />
                            </tooltip>
                        </Label>

                        <Button fx:id="sidebarLockButton" onAction="#onSidebarLockClicked" styleClass="sidebar-icon-button" text="⧉">
                                pickOnBounds="true">
                            <tooltip>
                                <Tooltip text="Lock sidebar" />
                            </tooltip>
                        </Button>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="avatar" text="JD" />
                        <VBox spacing="0">
                            <Label styleClass="top-user" text="Jakub Hlacik" />
                            <Label styleClass="top-role" text="User" />
                        </VBox>
                    </HBox>
                </VBox>

                <Button onAction="#onLogOutClicked" styleClass="nav-button" text="↩  Log out" />
            </children>
        </VBox>

        <!-- SIDEBAR HOVER TRIGGER -->
        <Pane fx:id="sidebarTrigger" layoutX="0" layoutY="0" prefWidth="20" style="-fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.topAnchor="0.0" />

    </children>
</AnchorPane>
