<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="logsRoot"
      spacing="10"
      stylesheets="@css/app.css,@css/admin.css"
      styleClass="logs-root"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.gui.AdminLogsController">

    <children>

        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="logs-filter-bar">
            <TextField fx:id="searchField"
                       promptText="Search logs..."
                       prefWidth="260"
                       styleClass="admin-input"/>

            <ComboBox fx:id="typeFilter"
                      prefWidth="140"
                      styleClass="admin-combo"/>

            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="dark-scroll"
                    VBox.vgrow="ALWAYS">

            <content>
                <VBox spacing="10">

                    <VBox spacing="8" styleClass="logs-section">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Scanning Logs" styleClass="logs-section-title"/>
                            <Label fx:id="scanningCountLabel" text="0" styleClass="logs-count-pill"/>
                            <Region HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <Label text="Logs related to document scanning activities."
                               styleClass="logs-description"/>

                        <TableView fx:id="scanningTable"
                                   prefHeight="190"
                                   minHeight="190"
                                   styleClass="logs-table"/>
                    </VBox>

                    <VBox spacing="8" styleClass="logs-section">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Export Logs" styleClass="logs-section-title"/>
                            <Label fx:id="exportCountLabel" text="0" styleClass="logs-count-pill"/>
                            <Region HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <Label text="Logs related to document export activities."
                               styleClass="logs-description"/>

                        <TableView fx:id="exportTable"
                                   prefHeight="190"
                                   minHeight="190"
                                   styleClass="logs-table"/>
                    </VBox>

                    <VBox spacing="8" styleClass="logs-section">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="User Logs" styleClass="logs-section-title"/>
                            <Label fx:id="userCountLabel" text="0" styleClass="logs-count-pill"/>
                            <Region HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <Label text="Logs related to user account changes."
                               styleClass="logs-description"/>

                        <TableView fx:id="userTable"
                                   prefHeight="190"
                                   minHeight="190"
                                   styleClass="logs-table"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>