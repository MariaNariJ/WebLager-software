<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.TextField?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.ListView?>
<VBox spacing="10"
      prefWidth="440"
      prefHeight="560"
      alignment="TOP_LEFT"
      stylesheets="@css/app.css,@css/userview.css"
      styleClass="profile-popup"
      fx:controller="dk.easv.gui.SelectProfileController"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>


    <!-- HEADER -->

    <VBox spacing="8">

        <Label text="Scan Setup"
               styleClass="popup-title"/>

        <Label text="Select a client, box and profile before starting the scan process."
               wrapText="true"
               styleClass="popup-subtitle"/>

    </VBox>

    <!-- CLIENT -->

    <VBox spacing="8">

        <Label text="Client"
               styleClass="field-label-dark"/>

        <StackPane>

            <TextField fx:id="txtClientSearch"
                       promptText="Search client..."
                       styleClass="combo-dark"/>

            <Label text="🔍"
                   mouseTransparent="true"
                   StackPane.alignment="CENTER_RIGHT"
                   styleClass="search-icon"/>

        </StackPane>

        <ListView fx:id="clientListView"
                  prefHeight="0"
                  maxHeight="80"
                  opacity="0"
                  styleClass="client-list"/>

    </VBox>

    <!-- BOX -->

    <VBox spacing="6">

        <Label text="Box ID"
               styleClass="field-label-dark"/>

        <TextField fx:id="txtBox"
                   styleClass="combo-dark"
                   promptText="Enter box ID..."
                   prefWidth="420"/>

    </VBox>

    <Region prefHeight="10"/>

    <VBox spacing="6">

        <Label text="Profile"
               styleClass="field-label-dark"/>

        <StackPane>

            <TextField fx:id="txtProfileSearch"
                       promptText="Search profile..."
                       styleClass="combo-dark"/>

            <Label text="🔍"
                   mouseTransparent="true"
                   StackPane.alignment="CENTER_RIGHT"
                   styleClass="search-icon"/>

        </StackPane>

    </VBox>

    <ScrollPane fitToWidth="true"
                prefHeight="180"
                maxHeight="180"
                styleClass="profile-scroll"
                hbarPolicy="NEVER">

        <content>
            <VBox fx:id="profileContainer"
                  spacing="8">

                <VBox.margin>
                    <Insets top="10"/>
                </VBox.margin>

            </VBox>
        </content>

    </ScrollPane>
    <Region prefHeight="26"/>

    <!-- ACTION BUTTONS -->

    <HBox spacing="12"
          alignment="CENTER_RIGHT">

        <Button text="Cancel"
                fx:id="cancelButton"
                onAction="#onCancelClicked"
                styleClass="popup-cancel"/>

        <Button text="Continue"
                fx:id="continueButton"
                onAction="#onContinueClicked"
                styleClass="popup-continue"/>

    </HBox>

</VBox>