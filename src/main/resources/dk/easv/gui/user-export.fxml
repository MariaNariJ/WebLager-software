<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.gui.UserExportController"
            stylesheets="@css/app.css,@css/user-export.css"
            styleClass="app-root">

    <children>

        <!-- RESPONSIVE WRAPPER -->

        <VBox spacing="8.0"
              fillWidth="true"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <padding>
                <Insets top="0" right="0" bottom="0" left="0"/>
            </padding>

            <!-- MAIN CONTENT -->

            <HBox spacing="8.0"
                  VBox.vgrow="ALWAYS">

                <!-- LEFT COLUMN -->

                <VBox spacing="10.0"
                      prefWidth="360.0"
                      minWidth="280.0"
                      maxWidth="420.0"
                      HBox.hgrow="NEVER"
                      styleClass="export-section">

                    <padding>
                        <Insets top="14" right="14" bottom="14" left="14"/>
                    </padding>

                    <Label text="1. Export options"
                           styleClass="export-section-title"/>

                    <Label text="Box"
                           styleClass="export-label"/>

                    <ComboBox fx:id="boxComboBox"
                              maxWidth="Infinity"
                              styleClass="export-combo-box"/>

                    <!-- SELECTED DOCUMENT -->

                    <VBox spacing="14.0"
                          styleClass="export-option-card">

                        <padding>
                            <Insets top="14" right="14" bottom="14" left="14"/>
                        </padding>

                        <HBox spacing="10.0">

                            <RadioButton/>

                            <FontIcon iconLiteral="fas-file-alt"
                                      styleClass="export-card-icon"/>

                        </HBox>

                        <Label text="Selected Document"
                               styleClass="export-card-title"/>

                        <Label text="Export the currently selected document."
                               wrapText="true"
                               styleClass="export-card-text"/>

                        <VBox spacing="4.0">

                            <Label text="File 1 of 45"
                                   styleClass="export-card-text"/>

                            <Label text="45 pages"
                                   styleClass="export-card-text"/>

                        </VBox>

                    </VBox>

                    <!-- MULTIPLE DOCUMENTS -->

                    <VBox spacing="14.0"
                          styleClass="export-option-card">

                        <padding>
                            <Insets top="14" right="14" bottom="14" left="14"/>
                        </padding>

                        <HBox spacing="10.0">

                            <RadioButton/>

                            <FontIcon iconLiteral="fas-copy"
                                      styleClass="export-card-icon"/>

                        </HBox>

                        <Label text="Multiple Documents"
                               styleClass="export-card-title"/>

                        <Label text="Choose multiple documents from the overview."
                               wrapText="true"
                               styleClass="export-card-text"/>

                        <Button text="Select Documents..."
                                styleClass="export-secondary-button"/>

                        <Label text="0 selected"
                               styleClass="export-card-text"/>

                    </VBox>

                    <!-- ALL DOCUMENTS -->

                    <VBox spacing="10.0"
                          styleClass="export-option-card">

                        <padding>
                            <Insets top="14" right="14" bottom="14" left="14"/>
                        </padding>

                        <HBox spacing="10.0">

                            <RadioButton/>

                            <FontIcon iconLiteral="fas-folder-open"
                                      styleClass="export-card-icon"/>

                        </HBox>

                        <Label text="All Documents in Current Box"
                               styleClass="export-card-title"/>

                        <Label text="Export all documents in the current box."
                               wrapText="true"
                               styleClass="export-card-text"/>

                        <VBox spacing="4.0">

                            <Label text="Box: BOX-102"
                                   styleClass="export-card-text"/>

                            <Label text="14 documents"
                                   styleClass="export-card-text"/>

                        </VBox>

                    </VBox>

                    <!-- METADATA -->

                    <VBox spacing="4.0">

                        <CheckBox text="Include metadata in export"
                                  styleClass="export-checkbox"/>

                        <Label text="A CSV file with document metadata will be included."
                               wrapText="true"
                               styleClass="export-card-text"/>

                    </VBox>

                </VBox>

                <!-- RIGHT COLUMN -->

                <VBox spacing="8.0"
                      VBox.vgrow="ALWAYS"
                      HBox.hgrow="ALWAYS">

                    <!-- EXPORT SETTINGS -->

                    <VBox spacing="10.0"
                          VBox.vgrow="ALWAYS"
                          styleClass="export-section">

                        <padding>
                            <Insets top="18" right="18" bottom="18" left="18"/>
                        </padding>

                        <Label text="2. Export settings"
                               styleClass="export-section-title"/>

                        <!-- EXPORT FORMAT -->

                        <VBox spacing="6.0">

                            <Label text="Export Format"
                                   styleClass="export-label"/>

                            <ComboBox fx:id="exportFormatComboBox"
                                      maxWidth="Infinity"
                                      styleClass="export-combo-box"/>

                            <Label text="Each document will be exported as a multi-page TIFF file."
                                   wrapText="true"
                                   styleClass="export-card-text"/>

                        </VBox>

                        <!-- FILE NAMING -->

                        <VBox spacing="6.0">

                            <Label text="File Naming"
                                   styleClass="export-label"/>

                            <ComboBox maxWidth="Infinity"
                                      styleClass="export-combo-box"/>

                            <Label text="Files will be named using the document name."
                                   wrapText="true"
                                   styleClass="export-card-text"/>

                        </VBox>

                    </VBox>

                    <!-- SAVE LOCATION -->

                    <VBox spacing="10.0"
                          VBox.vgrow="ALWAYS"
                          styleClass="export-section">

                        <padding>
                            <Insets top="18" right="18" bottom="18" left="18"/>
                        </padding>

                        <Label text="3. Export location"
                               styleClass="export-section-title"/>

                        <VBox spacing="8.0">

                            <Label text="Destination Folder"
                                   styleClass="export-label"/>

                            <HBox spacing="10.0">

                                <TextField fx:id="destinationField"
                                           HBox.hgrow="ALWAYS"
                                           maxWidth="Infinity"
                                           styleClass="export-text-field"/>

                                <Button fx:id="browseButton"
                                        text="Browse"
                                        minWidth="90.0"
                                        prefWidth="90.0"
                                        styleClass="export-secondary-button"/>

                            </HBox>

                        </VBox>

                        <CheckBox text="Open folder after export is complete"
                                  styleClass="export-checkbox"/>

                        <Region prefHeight="120.0"/>

                        <HBox alignment="CENTER">
                            <Button fx:id="exportButton"
                                    text="Export"
                                    prefWidth="220.0"
                                    prefHeight="55.0"
                                    styleClass="export-button"/>
                        </HBox>

                    </VBox>

                </VBox>

            </HBox>

        </VBox>

    </children>

</AnchorPane>