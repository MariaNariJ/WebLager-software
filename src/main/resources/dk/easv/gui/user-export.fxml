<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.gui.UserExportController"
            stylesheets="@css/app.css,@css/user-export.css"
            styleClass="app-root">

    <children>

        <!-- RESPONSIVE WRAPPER -->

        <VBox spacing="8.0"
              fillWidth="true"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <padding>
                <Insets top="0" right="0" bottom="0" left="0"/>
            </padding>

            <!-- MAIN CONTENT -->

            <HBox spacing="8.0"
                  VBox.vgrow="ALWAYS">

                <!-- LEFT COLUMN -->

                <VBox spacing="10.0"
                      prefWidth="360.0"
                      minWidth="280.0"
                      maxWidth="420.0"
                      HBox.hgrow="NEVER"
                      styleClass="export-section">

                    <padding>
                        <Insets top="14" right="14" bottom="14" left="14"/>
                    </padding>

                    <Label text="1. Export options"
                           styleClass="export-section-title"/>

                    <Label text="Box"
                           styleClass="export-label"/>

                    <ComboBox fx:id="boxComboBox"
                              maxWidth="Infinity"
                              styleClass="export-combo-box"/>

                    <!-- SELECTED DOCUMENT -->

                    <VBox spacing="14.0"
                          styleClass="export-option-card">

                        <padding>
                            <Insets top="14" right="14" bottom="14" left="14"/>
                        </padding>



                        <HBox spacing="10.0">

                            <RadioButton fx:id="selectedDocumentRadio"/>

                            <FontIcon iconLiteral="fas-file-alt"
                                      styleClass="export-card-icon"/>

                        </HBox>

                        <Label text="Selected Document"
                               styleClass="export-card-title"/>

                        <ComboBox fx:id="selectedDocumentComboBox"
                                  maxWidth="Infinity"
                                  styleClass="export-combo-box"/>

                        <VBox spacing="4.0">

                        </VBox>

                    </VBox>

                    <!-- MULTIPLE DOCUMENTS -->

                    <VBox spacing="14.0"
                          styleClass="export-option-card">

                        <padding>
                            <Insets top="14" right="14" bottom="14" left="14"/>
                        </padding>

                        <HBox spacing="10.0">

                            <RadioButton fx:id="multipleDocumentsRadio"/>

                            <FontIcon iconLiteral="fas-copy"
                                      styleClass="export-card-icon"/>

                        </HBox>

                        <Label text="Multiple Documents"
                               styleClass="export-card-title"/>

                        <Label text="Choose multiple documents from the overview."
                               wrapText="true"
                               styleClass="export-card-text"/>

                        <Button fx:id="selectDocumentsButton"
                                text="Select Documents..."
                                styleClass="export-secondary-button"/>

                        <Label fx:id="multipleSelectedCountLabel"
                               text="0 selected"
                               styleClass="export-card-text"/>

                    </VBox>

                    <!-- ALL DOCUMENTS -->

                    <VBox spacing="10.0"
                          styleClass="export-option-card">

                        <padding>
                            <Insets top="14" right="14" bottom="14" left="14"/>
                        </padding>

                        <HBox spacing="10.0">

                            <RadioButton fx:id="allDocumentsRadio"/>

                            <FontIcon iconLiteral="fas-folder-open"
                                      styleClass="export-card-icon"/>

                        </HBox>

                        <Label text="All Documents in Current Box"
                               styleClass="export-card-title"/>

                        <Label text="Export all documents in the current box."
                               wrapText="true"
                               styleClass="export-card-text"/>

                        <VBox spacing="4.0">

                            <Label fx:id="allDocumentsCountLabel"
                                   text="0 documents"
                                   styleClass="export-card-text"/>

                        </VBox>

                    </VBox>

                </VBox>

                <!-- RIGHT COLUMN -->

                <VBox spacing="8.0"
                      VBox.vgrow="ALWAYS"
                      HBox.hgrow="ALWAYS">

                    <!-- EXPORT SETTINGS -->

                    <VBox spacing="10.0"
                          VBox.vgrow="ALWAYS"
                          styleClass="export-section">

                        <padding>
                            <Insets top="18" right="18" bottom="18" left="18"/>
                        </padding>

                        <Label text="2. Export settings"
                               styleClass="export-section-title"/>

                        <!-- EXPORT FORMAT -->

                        <VBox spacing="6.0">

                            <Label text="Export Format"
                                   styleClass="export-label"/>

                            <ComboBox fx:id="exportFormatComboBox"
                                      maxWidth="Infinity"
                                      styleClass="export-combo-box"/>

                            <Label text="Each document will be exported as a multi-page TIFF file."
                                   wrapText="true"
                                   styleClass="export-card-text"/>

                        </VBox>

                    </VBox>

                    <!-- SAVE LOCATION -->

                    <VBox spacing="10.0"
                          VBox.vgrow="ALWAYS"
                          styleClass="export-section">

                        <padding>
                            <Insets top="18" right="18" bottom="18" left="18"/>
                        </padding>

                        <Label text="3. Export location"
                               styleClass="export-section-title"/>

                        <VBox spacing="8.0">

                            <Label text="Destination Folder"
                                   styleClass="export-label"/>

                            <HBox spacing="10.0">

                                <TextField fx:id="destinationField"
                                           HBox.hgrow="ALWAYS"
                                           maxWidth="Infinity"
                                           styleClass="export-text-field"/>

                                <Button fx:id="browseButton"
                                        text="Browse"
                                        minWidth="90.0"
                                        prefWidth="90.0"
                                        styleClass="export-secondary-button"/>

                            </HBox>

                        </VBox>

                        <CheckBox fx:id="openFolderCheckBox"
                                  text="Open folder after export is complete"
                                  styleClass="export-checkbox"/>

                        <HBox spacing="24.0"
                              alignment="CENTER_LEFT"
                              styleClass="export-status-card">

                            <padding>
                                <Insets top="16" right="18" bottom="16" left="18"/>
                            </padding>

                            <!-- LEFT SIDE -->

                            <HBox spacing="14.0"
                                  alignment="CENTER_LEFT"
                                  HBox.hgrow="ALWAYS">

                                <FontIcon iconLiteral="fas-check-circle"
                                          styleClass="export-status-icon"/>

                                <VBox spacing="4.0"
                                      HBox.hgrow="ALWAYS">

                                    <Label text="Export Status"
                                           styleClass="export-status-title"/>

                                    <Label fx:id="exportStatusLabel"
                                           text="Ready to export documents"
                                           styleClass="export-status-subtitle"/>

                                    <HBox spacing="30.0">

                                        <VBox spacing="2.0">

                                            <Label text="Documents"
                                                   styleClass="export-status-label"/>

                                            <Label fx:id="exportDocumentCountLabel"
                                                   text="0 selected"
                                                   styleClass="export-status-value"/>

                                        </VBox>

                                        <VBox spacing="2.0">

                                            <Label text="Format"
                                                   styleClass="export-status-label"/>

                                            <Label fx:id="exportFormatStatusLabel"
                                                   text="TIFF Export"
                                                   styleClass="export-status-value"/>

                                        </VBox>

                                    </HBox>

                                </VBox>

                            </HBox>

                            <!-- BUTTON -->

                            <Button fx:id="exportButton"
                                    text="Export"
                                    prefWidth="220.0"
                                    prefHeight="58.0"
                                    styleClass="export-button"/>

                        </HBox>

                    </VBox>

                </VBox>

            </HBox>

        </VBox>

    </children>

</AnchorPane>