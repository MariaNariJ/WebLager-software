<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.image.ImageView?>
<AnchorPane prefHeight="820.0"
            prefWidth="1440.0"
            styleClass="app-root"
            stylesheets="@css/app.css,@css/user-qa.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.gui.UserQaController">

    <children>

        <VBox spacing="0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <children>

                <HBox spacing="8"
                      VBox.vgrow="ALWAYS">

                    <!-- LEFT QUEUE -->
                    <VBox maxWidth="310.0"
                          minWidth="310.0"
                          prefWidth="315.0"
                          spacing="12"
                          styleClass="side-panel">

                        <padding>
                            <Insets top="14"
                                    right="10"
                                    bottom="12"
                                    left="12"/>
                        </padding>

                        <children>

                            <HBox alignment="CENTER_LEFT"
                                  spacing="8">

                                <Label text="QA Queue"
                                       styleClass="section-title"/>

                                <Label fx:id="queueCountLabel"
                                       styleClass="count-badge"
                                       text="0"/>
                            </HBox>

                            <TextField promptText="Search documents..."
                                       styleClass="search-field"/>

                            <ScrollPane fitToWidth="true"
                                        hbarPolicy="NEVER"
                                        vbarPolicy="AS_NEEDED"
                                        VBox.vgrow="ALWAYS"
                                        styleClass="transparent-scroll">

                                <content>

                                    <VBox fx:id="queueContainer"
                                          spacing="12"/>

                                </content>

                            </ScrollPane>

                        </children>

                    </VBox>

                    <!-- CENTER PREVIEW -->
                    <VBox spacing="12"
                          styleClass="qa-panel"
                          HBox.hgrow="ALWAYS">

                        <padding>
                            <Insets top="14"
                                    right="12"
                                    bottom="12"
                                    left="12"/>
                        </padding>

                        <children>

                            <HBox alignment="CENTER_LEFT">

                                <VBox spacing="2">

                                    <Label styleClass="qa-section-title"
                                           text="Document ID: 4743442"/>

                                    <Label styleClass="muted-text"
                                           text="File 1 of 5"/>

                                </VBox>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Button styleClass="small-button"
                                        text="-"/>

                                <Label styleClass="qa-zoom-label"
                                       text="100%"/>

                                <Button styleClass="small-button"
                                        text="+"/>

                            </HBox>

                            <ScrollPane fx:id="previewScrollPane"
                                        fitToWidth="true"
                                        fitToHeight="true"
                                        pannable="true"
                                        styleClass="preview-scroll">

                                <content>

                                    <StackPane alignment="CENTER"
                                               styleClass="qa-preview-area">

                                        <children>

                                            <ImageView fx:id="previewImage"
                                                       preserveRatio="true"
                                                       smooth="true"/>

                                        </children>

                                    </StackPane>

                                </content>

                            </ScrollPane>

                            <HBox alignment="CENTER"
                                  spacing="32"
                                  prefHeight="74"
                                  minHeight="74"
                                  maxHeight="74"
                                  styleClass="qa-toolbar">

                                <children>

                                    <VBox alignment="CENTER"
                                          spacing="2">

                                        <Label text="↺"
                                               styleClass="toolbar-icon"/>

                                        <Label text="Rotate Left"
                                               styleClass="toolbar-label"/>

                                        <Label text="(Q)"
                                               styleClass="toolbar-key"/>

                                    </VBox>

                                    <VBox alignment="CENTER"
                                          spacing="2">

                                        <Label text="↻"
                                               styleClass="toolbar-icon"/>

                                        <Label text="Rotate Right"
                                               styleClass="toolbar-label"/>

                                        <Label text="(E)"
                                               styleClass="toolbar-key"/>

                                    </VBox>

                                    <VBox alignment="CENTER"
                                          spacing="2">

                                        <Label text="⟲"
                                               styleClass="toolbar-icon"/>

                                        <Label text="Reset Rotation"
                                               styleClass="toolbar-label"/>

                                        <Label text="(R)"
                                               styleClass="toolbar-key"/>

                                    </VBox>

                                    <VBox alignment="CENTER"
                                          spacing="2">

                                        <Label text="↔"
                                               styleClass="toolbar-icon"/>

                                        <Label text="Fit Width"
                                               styleClass="toolbar-label"/>

                                        <Label text="(F)"
                                               styleClass="toolbar-key"/>

                                    </VBox>

                                    <VBox alignment="CENTER"
                                          spacing="2">

                                        <Label text="▣"
                                               styleClass="toolbar-icon"/>

                                        <Label text="Reset Zoom"
                                               styleClass="toolbar-label"/>

                                        <Label text="(0)"
                                               styleClass="toolbar-key"/>

                                    </VBox>

                                    <VBox alignment="CENTER"
                                          spacing="2">

                                        <Button text="←"
                                                onAction="#onPreviousPage"/>

                                        <Label text="Previous"
                                               styleClass="toolbar-label"/>

                                        <Label text="(A)"
                                               styleClass="toolbar-key"/>

                                    </VBox>

                                    <VBox alignment="CENTER"
                                          spacing="2">

                                        <Button text="→"
                                                onAction="#onNextPage"/>

                                        <Label text="Next"
                                               styleClass="toolbar-label"/>

                                        <Label text="(D)"
                                               styleClass="toolbar-key"/>

                                    </VBox>

                                </children>

                            </HBox>

                        </children>

                    </VBox>

                    <!-- RIGHT INFO -->
                    <VBox maxWidth="330"
                          minWidth="330"
                          prefWidth="330"
                          spacing="12"
                          styleClass="qa-panel">

                        <padding>
                            <Insets top="14"
                                    right="10"
                                    bottom="12"
                                    left="12"/>
                        </padding>

                        <children>

                            <Label text="Document Information"
                                   styleClass="qa-section-title"/>

                            <GridPane hgap="10"
                                      vgap="10">

                                <columnConstraints>
                                    <ColumnConstraints/>
                                    <ColumnConstraints/>
                                </columnConstraints>

                                <rowConstraints>
                                    <RowConstraints/>
                                    <RowConstraints/>
                                    <RowConstraints/>
                                    <RowConstraints/>
                                    <RowConstraints/>
                                    <RowConstraints/>
                                </rowConstraints>

                                <padding>
                                    <Insets left="4"/>
                                </padding>

                                <children>

                                    <Label text="Client"
                                           styleClass="qa-info-label"
                                           GridPane.columnIndex="0"
                                           GridPane.rowIndex="0"/>

                                    <Label fx:id="clientLabel"
                                           text="SEA"
                                           styleClass="qa-info-value"
                                           prefWidth="199"
                                           prefHeight="30"
                                           GridPane.columnIndex="1"
                                           GridPane.rowIndex="0"/>

                                    <Label text="Box"
                                           styleClass="qa-info-label"
                                           GridPane.columnIndex="0"
                                           GridPane.rowIndex="1"/>

                                    <Label fx:id="boxLabel"
                                           text="BOX_001"
                                           styleClass="qa-info-value"
                                           prefWidth="199"
                                           prefHeight="30"
                                           GridPane.columnIndex="1"
                                           GridPane.rowIndex="1"/>

                                    <Label text="Document Name"
                                           styleClass="qa-info-label"
                                           GridPane.columnIndex="0"
                                           GridPane.rowIndex="2"/>

                                    <Label fx:id="documentNameLabel"
                                           text="Document 1"
                                           styleClass="qa-info-value"
                                           prefWidth="199"
                                           prefHeight="30"
                                           GridPane.columnIndex="1"
                                           GridPane.rowIndex="2"/>

                                    <Label text="Date"
                                           styleClass="qa-info-label"
                                           GridPane.columnIndex="0"
                                           GridPane.rowIndex="3"/>

                                    <Label fx:id="dateLabel"
                                           text="22-05-2026"
                                           styleClass="qa-info-value"
                                           prefWidth="199"
                                           prefHeight="30"
                                           GridPane.columnIndex="1"
                                           GridPane.rowIndex="3"/>

                                    <Label text="Barcode"
                                           styleClass="qa-info-label"
                                           GridPane.columnIndex="0"
                                           GridPane.rowIndex="4"/>

                                    <Label fx:id="barcodeLabel"
                                           text="4743442"
                                           styleClass="qa-info-value"
                                           prefWidth="199"
                                           prefHeight="30"
                                           GridPane.columnIndex="1"
                                           GridPane.rowIndex="4"/>

                                    <Label text="Scan Profile"
                                           styleClass="qa-info-label"
                                           GridPane.columnIndex="0"
                                           GridPane.rowIndex="5"/>

                                    <Label fx:id="scanProfileLabel"
                                           text="High Brightness"
                                           styleClass="qa-info-value"
                                           prefWidth="199"
                                           prefHeight="30"
                                           GridPane.columnIndex="1"
                                           GridPane.rowIndex="5"/>

                                </children>

                            </GridPane>

                            <VBox spacing="8"
                                  styleClass="qa-action-card">

                                <children>

                                    <Label text="QA Status"
                                           styleClass="qa-section-title"/>

                                    <HBox alignment="CENTER_LEFT"
                                          spacing="8">

                                        <Label text="●"
                                               styleClass="qa-status-dot"/>

                                        <Label fx:id="qaStatusLabel"
                                               text="Waiting for QA"
                                               styleClass="muted-text"/>

                                    </HBox>

                                </children>

                            </VBox>

                            <VBox spacing="8"
                                  styleClass="qa-notes-card"
                                  VBox.vgrow="ALWAYS">

                                <children>

                                    <Label text="QA Notes"
                                           styleClass="qa-section-title"/>

                                    <TextArea promptText="Add notes or comments..."
                                              styleClass="qa-notes-area"
                                              VBox.vgrow="ALWAYS"/>

                                </children>

                            </VBox>

                            <Button fx:id="approveButton"
                                    text="✓ Approve Document"
                                    onAction="#onApproveDocument"
                                    prefHeight="46"
                                    maxWidth="Infinity"
                                    styleClass="qa-approve-button"/>

                        </children>

                    </VBox>

                </HBox>

            </children>

        </VBox>

    </children>

</AnchorPane>