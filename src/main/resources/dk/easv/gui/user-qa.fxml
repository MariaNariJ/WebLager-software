<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="820.0"
            prefWidth="1440.0"
            styleClass="app-root"
            stylesheets="@css/app.css,@css/user-qa.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.gui.UserQaController">

    <children>
        <VBox spacing="0"
              AnchorPane.topAnchor="8"
              AnchorPane.bottomAnchor="8"
              AnchorPane.leftAnchor="8"
              AnchorPane.rightAnchor="8">

            <children>

                <HBox spacing="8"
                      VBox.vgrow="ALWAYS">

                    <!-- LEFT QUEUE -->
                    <VBox spacing="12"
                          prefWidth="310"
                          minWidth="310"
                          maxWidth="310"
                          styleClass="qa-panel">

                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>

                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="QA Queue"
                                       styleClass="qa-section-title"/>

                                <Label text="3"
                                       styleClass="qa-count-pill"/>
                            </HBox>

                            <TextField promptText="Search documents..."
                                       styleClass="dark-field"/>

                            <VBox spacing="10">

                                <VBox spacing="7"
                                      styleClass="qa-document-card-selected">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <Label text="4743442"
                                                   styleClass="qa-document-title"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Label text="5 pages"
                                                   styleClass="qa-small-text"/>
                                        </HBox>

                                        <Label text="SEA - Syddansk Erhvervsakademi"
                                               styleClass="muted-text"/>

                                        <Label text="BOX_001  •  22-05-2026"
                                               styleClass="qa-small-text"/>

                                        <Label text="Waiting for QA"
                                               styleClass="qa-warning-text"/>
                                    </children>
                                </VBox>

                                <VBox spacing="7"
                                      styleClass="qa-document-card">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <Label text="4743441"
                                                   styleClass="qa-document-title"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Label text="3 pages"
                                                   styleClass="qa-small-text"/>
                                        </HBox>

                                        <Label text="Nordic Transport Group"
                                               styleClass="muted-text"/>

                                        <Label text="BOX_002  •  21-05-2026"
                                               styleClass="qa-small-text"/>

                                        <Label text="Waiting for QA"
                                               styleClass="qa-warning-text"/>
                                    </children>
                                </VBox>

                                <VBox spacing="7"
                                      styleClass="qa-document-card">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <Label text="4743440"
                                                   styleClass="qa-document-title"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Label text="8 pages"
                                                   styleClass="qa-small-text"/>
                                        </HBox>

                                        <Label text="TechSolutions ApS"
                                               styleClass="muted-text"/>

                                        <Label text="BOX_003  •  21-05-2026"
                                               styleClass="qa-small-text"/>

                                        <Label text="Waiting for QA"
                                               styleClass="qa-warning-text"/>
                                    </children>
                                </VBox>

                            </VBox>
                        </children>
                    </VBox>

                    <!-- CENTER PREVIEW -->
                    <VBox spacing="12"
                          HBox.hgrow="ALWAYS"
                          styleClass="qa-panel">

                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>

                        <children>
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="2">
                                    <Label text="Document ID: 4743442"
                                           styleClass="qa-section-title"/>

                                    <Label text="File 1 of 5"
                                           styleClass="muted-text"/>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Button text="-"
                                        styleClass="small-button"/>

                                <Label text="100%"
                                       styleClass="qa-zoom-label"/>

                                <Button text="+"
                                        styleClass="small-button"/>
                            </HBox>

                            <StackPane VBox.vgrow="ALWAYS"
                                       styleClass="qa-preview-area">

                                <children>
                                    <VBox alignment="TOP_CENTER"
                                          spacing="18"
                                          styleClass="qa-paper-preview"
                                          maxWidth="430"
                                          maxHeight="570">

                                        <padding>
                                            <Insets top="28" right="28" bottom="28" left="28"/>
                                        </padding>

                                        <children>
                                            <HBox>
                                                <Label text="Dokumenter"
                                                       styleClass="qa-paper-title"/>

                                                <Region HBox.hgrow="ALWAYS"/>

                                                <Label text="Global ID: 4743442"
                                                       styleClass="qa-paper-text"/>
                                            </HBox>

                                            <GridPane hgap="26" vgap="8">
                                                <children>
                                                    <Label text="Arkiv:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="qa-paper-small"/>
                                                    <Label text="Dokumentarkiv" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="qa-paper-small"/>

                                                    <Label text="Kommune:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="qa-paper-small"/>
                                                    <Label text="Esbjerg" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="qa-paper-small"/>

                                                    <Label text="Pages:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="qa-paper-small"/>
                                                    <Label text="5" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="qa-paper-small"/>
                                                </children>
                                            </GridPane>

                                            <Region VBox.vgrow="ALWAYS"/>

                                            <Label text="||||||||||||||||||||||||||||"
                                                   styleClass="qa-barcode"/>

                                            <Label text="4743442"
                                                   styleClass="qa-paper-text"/>

                                            <Label text="SEP"
                                                   styleClass="qa-paper-text"/>
                                        </children>
                                    </VBox>
                                </children>
                            </StackPane>

                            <HBox alignment="CENTER"
                                  spacing="28"
                                  styleClass="qa-toolbar">

                                <children>
                                    <Button text="↺&#10;Rotate Left&#10;(Q)"
                                            styleClass="toolbar-button"/>

                                    <Button text="↻&#10;Rotate Right&#10;(E)"
                                            styleClass="toolbar-button"/>

                                    <Button text="↔&#10;Fit Width"
                                            styleClass="toolbar-button"/>

                                    <Button text="▣&#10;Reset Zoom"
                                            styleClass="toolbar-button"/>

                                    <Button text="→&#10;Next File&#10;(D)"
                                            styleClass="toolbar-button"/>

                                    <Button text="←&#10;Previous File&#10;(A)"
                                            styleClass="toolbar-button"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <!-- RIGHT INFO -->
                    <VBox spacing="12"
                          prefWidth="330"
                          minWidth="330"
                          maxWidth="330"
                          styleClass="qa-panel">

                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>

                        <children>
                            <Label text="Document Information"
                                   styleClass="qa-section-title"/>

                            <GridPane hgap="10" vgap="10">
                                <children>
                                    <Label text="Client" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="qa-info-label"/>
                                    <Label text="SEA" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="qa-info-value"/>

                                    <Label text="Box" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="qa-info-label"/>
                                    <Label text="BOX_001" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="qa-info-value"/>

                                    <Label text="Document Name" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="qa-info-label"/>
                                    <Label text="q" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="qa-info-value"/>

                                    <Label text="Date" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="qa-info-label"/>
                                    <Label text="22-05-2026" GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="qa-info-value"/>

                                    <Label text="Barcode" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="qa-info-label"/>
                                    <Label text="4743442" GridPane.rowIndex="4" GridPane.columnIndex="1" styleClass="qa-info-value"/>

                                    <Label text="Scan Profile" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="qa-info-label"/>
                                    <Label text="High Brightness" GridPane.rowIndex="5" GridPane.columnIndex="1" styleClass="qa-info-value"/>
                                </children>
                            </GridPane>

                            <VBox spacing="8"
                                  styleClass="qa-action-card">
                                <children>
                                    <Label text="QA Status"
                                           styleClass="qa-section-title"/>

                                    <HBox spacing="8"
                                          alignment="CENTER_LEFT">
                                        <Label text="●"
                                               styleClass="qa-status-dot"/>

                                        <Label text="Waiting for QA"
                                               styleClass="muted-text"/>
                                    </HBox>
                                </children>
                            </VBox>

                            <VBox spacing="8"
                                  styleClass="qa-notes-card"
                                  VBox.vgrow="ALWAYS">
                                <children>
                                    <Label text="QA Notes"
                                           styleClass="qa-section-title"/>

                                    <TextArea promptText="Add notes or comments..."
                                              styleClass="qa-notes-area"
                                              VBox.vgrow="ALWAYS"/>
                                </children>
                            </VBox>

                            <Button text="✓ Approve Document"
                                    styleClass="qa-approve-button"
                                    maxWidth="Infinity"/>
                        </children>
                    </VBox>

                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>